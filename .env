# Site Configuration
# Copy this file to .env.local and fill in your values

# Site title (appears in header, metadata, and SEO)
NEXT_PUBLIC_SITE_TITLE="Ann Naser Nabil"

# Site description (for SEO and meta tags)
NEXT_PUBLIC_SITE_DESCRIPTION="A blog about technology, programming, and more"

# Author name
NEXT_PUBLIC_SITE_AUTHOR="Ann Naser Nabil"

# Site URL (for social sharing cards, e.g., https://username.github.io/repo-name)
NEXT_PUBLIC_SITE_URL="https://DswithAnn/DswithAnn.github.io"

# Twitter handle (without @ symbol)
NEXT_PUBLIC_TWITTER_HANDLE="yourhandle"

# Base path - automatically set by GitHub Actions
# Leave empty for root domains (username.github.io)
# Set to /repo-name for project pages (username.github.io/repo-name)
# NEXT_PUBLIC_BASE_PATH=""
